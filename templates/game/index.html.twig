{% extends 'base.html.twig' %}

{% block title %}{{ bakery.name }}{% endblock %}

{% block navbar %}
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <span class="navbar-brand mb-0 h1">🎂 {{ bakery.name }}</span>
            <div class="d-flex align-items-center gap-3">
                {{ include('game/_timer.html.twig') }}
                <div id="navbar-stats" class="d-flex gap-4 text-white small align-items-center">
                    <span>💰 ${{ bakery.money|number_format(2) }}</span>
                    <span>⭐ {{ bakery.reputation }}/100</span>
                    <span>📅 Day {{ bakery.day }}</span>
                </div>
                <form method="post" action="{{ path('game_restart') }}"
                      onsubmit="return confirm('Start a new game? Your current progress will be lost.')">
                    <button class="btn btn-outline-danger btn-sm">New Game</button>
                </form>
            </div>
        </div>
    </nav>
{% endblock %}

{% block body %}
    {% set hasBlocking = blockingOrders is not empty %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h4 mb-0">Active Orders</h2>
        {% if dayExpired %}
            <form method="post" action="{{ path('game_advance_day') }}">
                <button class="btn btn-warning btn-sm">End Day →</button>
            </form>
        {% elseif hasBlocking %}
            <span class="text-danger small fw-semibold">⚠️ Complete today's orders before advancing</span>
        {% else %}
            <form method="post" action="{{ path('game_advance_day') }}">
                <button class="btn btn-outline-secondary btn-sm">Advance Day →</button>
            </form>
        {% endif %}
    </div>

    <turbo-frame id="orders">
        {% if orders is empty %}
            <p class="text-muted">No active orders. Advance the day to get new ones.</p>
        {% else %}
            <div class="row g-3">
                {% for order in orders %}
                    {% set isUnspawned = order.spawnAt.timestamp > serverNow %}
                    <div class="col-md-4 order-card {{ isUnspawned ? 'd-none' : '' }}"
                         data-spawn-at="{{ order.spawnAt.timestamp }}">
                        <div class="card h-100 shadow-sm {{ order.status.value == 'in_progress' ? 'border-warning' : '' }}">
                            <div class="card-body">
                                <div class="d-flex align-items-start justify-content-between mb-3">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="fs-3">{{ order.avatar }}</span>
                                        <div class="fw-semibold">{{ order.customerName }}</div>
                                    </div>
                                    {% if order.status.value == 'in_progress' %}
                                        <span class="badge bg-warning text-dark">In Progress</span>
                                    {% else %}
                                        <span class="badge bg-secondary">Pending</span>
                                    {% endif %}
                                </div>
                                <ul class="list-unstyled small mb-3">
                                    <li>🎂 {{ order.requiredSize.value }}</li>
                                    <li>🍦 {{ order.requiredFrostingFlavor.label }}</li>
                                    <li>📏 {{ order.requiredLayers }} layer{{ order.requiredLayers > 1 ? 's' : '' }}</li>
                                    {% if order.requiredToppings %}
                                        <li>✨ {{ order.requiredToppings|map(t => t.label)|join(', ') }}</li>
                                    {% endif %}
                                </ul>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span class="text-success fw-semibold">${{ order.payout|number_format(2) }}</span>
                                    {% if order.status.value == 'in_progress' %}
                                        <form method="post" action="{{ path('cake_build', {id: order.id}) }}" data-turbo-frame="_top">
                                            <button class="btn btn-warning btn-sm">Continue →</button>
                                        </form>
                                    {% else %}
                                        <form method="post" action="{{ path('cake_build', {id: order.id}) }}" data-turbo-frame="_top">
                                            <button class="btn btn-primary btn-sm">Bake</button>
                                        </form>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </turbo-frame>

    {{ include('game/_shop.html.twig') }}
{% endblock %}
