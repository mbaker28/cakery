{% extends 'base.html.twig' %}

{% block title %}Stock Up — {{ bakery.name }}{% endblock %}

{% block navbar %}
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <span class="navbar-brand mb-0 h1">🎂 {{ bakery.name }}</span>
            <div class="d-flex align-items-center gap-3">
                <div id="navbar-stats" class="d-flex gap-4 text-white small align-items-center">
                    <span id="navbar-money">💰 ${{ bakery.money|number_format(2) }}</span>
                    <span>⭐ {{ bakery.reputation }}/100</span>
                    <span>📅 Day {{ bakery.day }} / {{ bakery.maxDays }}</span>
                </div>
                <form method="post" action="{{ path('game_restart') }}"
                      onsubmit="return confirm('Start a new game? Your current progress will be lost.')">
                    <button class="btn btn-outline-danger btn-sm">New Game</button>
                </form>
            </div>
        </div>
    </nav>
{% endblock %}

{% block body %}
    {% set nextDay = bakery.day + 1 %}
    {% set isFinalDay = nextDay >= bakery.maxDays %}
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h2 class="h4 mb-1">Stock Up{% if isFinalDay %} — Final Day{% endif %}</h2>
            <p class="text-muted mb-0">
                Day {{ nextDay }} will bring
                <strong>{{ nextDayOrders }} order{{ nextDayOrders > 1 ? 's' : '' }}</strong>.
                Make sure you have enough supplies to fulfil every one.
            </p>
        </div>
        <form method="post" action="{{ path('game_start_day') }}">
            <button class="btn btn-success btn-lg">
                {{ isFinalDay ? '🏁 Start Final Day →' : 'Start Day ' ~ nextDay ~ ' →' }}
            </button>
        </form>
    </div>

    <h6 class="text-muted text-uppercase small fw-semibold mt-4 mb-2">Upgrades</h6>
    <div class="row g-3 mb-4">
        {% for upgrade in upgrades %}
            {% set currentLevel = bakery.getUpgradeLevel(upgrade) %}
            {% set maxed = currentLevel >= upgrade.maxLevel %}
            {% set nextLevel = currentLevel + 1 %}
            {% set cost = maxed ? 0 : upgrade.costForLevel(nextLevel) %}
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <div class="fw-semibold">{{ upgrade.label }}</div>
                            <div class="text-muted small">{{ upgrade.description }}</div>
                            {% if upgrade.maxLevel > 1 %}
                                <div class="small mt-1 text-secondary">
                                    Level {{ currentLevel }}/{{ upgrade.maxLevel }}
                                    {% if not maxed %} → {{ upgrade.effectForLevel(nextLevel) }}{% endif %}
                                </div>
                            {% endif %}
                        </div>
                        {% if maxed %}
                            <span class="badge bg-success flex-shrink-0">Owned</span>
                        {% else %}
                            <form method="post" action="{{ path('game_purchase_upgrade') }}" class="flex-shrink-0">
                                <input type="hidden" name="upgrade" value="{{ upgrade.value }}">
                                <button class="btn btn-sm btn-outline-primary {{ bakery.money < cost ? 'disabled' : '' }}">
                                    ${{ cost|number_format(2) }}
                                </button>
                            </form>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    {% set groups = ['Base Ingredients', 'Frostings', 'Toppings'] %}
    {% for group in groups %}
        <h6 class="text-muted text-uppercase small fw-semibold mt-4 mb-2">{{ group }}</h6>
        <div class="row g-3 mb-2">
            {% for item in restockables|filter(i => i.group == group) %}
                {{ include('game/_shop_card.html.twig') }}
            {% endfor %}
        </div>
    {% endfor %}
{% endblock %}
