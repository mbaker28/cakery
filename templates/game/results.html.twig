{% extends 'base.html.twig' %}

{% block title %}Results — {{ bakery.name }}{% endblock %}

{% block body %}
{% set completionPct = total > 0 ? (completionRate * 100)|round : 0 %}
{% set perfectPct    = completed > 0 ? (perfectOrders / completed * 100)|round : 0 %}

{% set gradeLabel = {
    'S': 'Perfect Run',
    'A': 'Outstanding',
    'B': 'Solid Work',
    'C': 'Getting By',
    'D': 'Needs Work',
    'F': 'Back to Basics',
}[grade] %}


<div class="mx-auto" style="max-width:540px">

    <div class="grade-{{ grade }} rounded-3 p-4 text-center mb-3">
        <div class="display-1 fw-bold lh-1">{{ grade }}</div>
        <div class="fs-5 fw-semibold mt-2 opacity-75">{{ gradeLabel }}</div>
        <div class="small mt-1 opacity-50">{{ bakery.name }} · {{ bakery.maxDays }}-day run</div>
    </div>

    <div class="row g-3 mb-3">
        <div class="col-6">
            <div class="card border-0 bg-light text-center h-100">
                <div class="card-body py-3">
                    <div class="h3 fw-bold mb-0 {{ completionPct >= 80 ? 'text-success' : (completionPct < 50 ? 'text-danger' : '') }}">
                        {{ completionPct }}%
                    </div>
                    <div class="small text-uppercase text-muted" style="letter-spacing:.06em;font-size:.68rem">Completion rate</div>
                </div>
            </div>
        </div>
        <div class="col-6">
            <div class="card border-0 bg-light text-center h-100">
                <div class="card-body py-3">
                    <div class="h3 fw-bold mb-0">{{ bakery.reputation }}<span class="fs-5 fw-normal text-muted">/100</span></div>
                    <div class="small text-uppercase text-muted" style="letter-spacing:.06em;font-size:.68rem">Final reputation</div>
                </div>
            </div>
        </div>
        <div class="col-6">
            <div class="card border-0 bg-light text-center h-100">
                <div class="card-body py-3">
                    <div class="h3 fw-bold mb-0">{{ completed }}<span class="fs-5 fw-normal text-muted">/{{ total }}</span></div>
                    <div class="small text-uppercase text-muted" style="letter-spacing:.06em;font-size:.68rem">Orders completed</div>
                </div>
            </div>
        </div>
        <div class="col-6">
            <div class="card border-0 bg-light text-center h-100">
                <div class="card-body py-3">
                    <div class="h3 fw-bold mb-0 {{ perfectPct >= 80 ? 'text-success' : '' }}">{{ perfectPct }}%</div>
                    <div class="small text-uppercase text-muted" style="letter-spacing:.06em;font-size:.68rem">Delivered excited</div>
                </div>
            </div>
        </div>
        <div class="col-6">
            <div class="card border-0 bg-light text-center h-100">
                <div class="card-body py-3">
                    <div class="h3 fw-bold mb-0 text-success">${{ bakery.money|number_format(2) }}</div>
                    <div class="small text-uppercase text-muted" style="letter-spacing:.06em;font-size:.68rem">Final balance</div>
                </div>
            </div>
        </div>
        <div class="col-6">
            <div class="card border-0 bg-light text-center h-100">
                <div class="card-body py-3">
                    <div class="h3 fw-bold mb-0">{{ bakery.day }}</div>
                    <div class="small text-uppercase text-muted" style="letter-spacing:.06em;font-size:.68rem">Days played</div>
                </div>
            </div>
        </div>
    </div>

    <form method="post" action="{{ path('game_restart') }}">
        <button class="btn btn-primary btn-lg w-100">Play Again</button>
    </form>

</div>
{% endblock %}
