<turbo-frame id="cake-builder">
    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="card-title mb-4">Build your cake</h5>

            {# Size #}
            <div class="mb-4">
                <label class="form-label fw-semibold">Size</label>
                <div class="d-flex gap-2 flex-wrap">
                    {% for size in sizes %}
                        <form method="post" action="{{ path('cake_set_size', {id: order.id, cakeId: cake.id}) }}">
                            <input type="hidden" name="size" value="{{ size.value }}">
                            <button class="btn btn-sm {{ cake.size == size ? 'btn-primary' : 'btn-outline-secondary' }}">
                                {{ size.value }}
                            </button>
                        </form>
                    {% endfor %}
                </div>
            </div>

            {# Layers #}
            <div class="mb-4">
                <label class="form-label fw-semibold">Layers</label>
                <div class="d-flex gap-2">
                    {% for i in 1..5 %}
                        <form method="post" action="{{ path('cake_set_layers', {id: order.id, cakeId: cake.id}) }}">
                            <input type="hidden" name="layers" value="{{ i }}">
                            <button class="btn btn-sm {{ cake.layers == i ? 'btn-primary' : 'btn-outline-secondary' }}">
                                {{ i }}
                            </button>
                        </form>
                    {% endfor %}
                </div>
            </div>

            {# Frosting #}
            <div class="mb-4">
                <label class="form-label fw-semibold">Frosting</label>
                <div class="d-flex gap-2 flex-wrap">
                    {% for flavor in flavors %}
                        <form method="post" action="{{ path('cake_set_frosting', {id: order.id, cakeId: cake.id}) }}">
                            <input type="hidden" name="flavor" value="{{ flavor.value }}">
                            <button class="btn btn-sm {{ cake.frostingFlavor == flavor ? 'btn-primary' : 'btn-outline-secondary' }}">
                                {{ flavor.value }}
                            </button>
                        </form>
                    {% endfor %}
                </div>
            </div>

            {# Toppings #}
            <div class="mb-4">
                <label class="form-label fw-semibold">Toppings</label>
                <div class="d-flex gap-2 flex-wrap">
                    {% for topping in toppings %}
                        <form method="post" action="{{ path('cake_toggle_topping', {id: order.id, cakeId: cake.id}) }}">
                            <input type="hidden" name="topping" value="{{ topping.value }}">
                            <button class="btn btn-sm {{ cake.toppings and topping in cake.toppings ? 'btn-primary' : 'btn-outline-secondary' }}">
                                {{ topping.value }}
                            </button>
                        </form>
                    {% endfor %}
                </div>
            </div>

            {# Ingredient requirements #}
            <div class="mb-4">
                <label class="form-label fw-semibold">Ingredients needed</label>
                {% if requirements %}
                    <ul class="list-unstyled small mb-0">
                        {% for key, needed in requirements %}
                            {% set available = bakery.inventory[key] ?? 0 %}
                            <li class="d-flex justify-content-between py-1 border-bottom">
                                <span>{{ key|capitalize }}</span>
                                <span class="{{ available >= needed ? 'text-success' : 'text-danger' }} fw-semibold">
                                    {{ needed }} needed &middot; {{ available }} in stock
                                </span>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p class="text-muted small mb-0">Select a size and layer count to see requirements.</p>
                {% endif %}
            </div>

            {# Bake button — data-turbo-frame="_top" escapes the frame for full-page navigation #}
            <form method="post" action="{{ path('cake_bake', {id: order.id, cakeId: cake.id}) }}" data-turbo-frame="_top">
                <button
                    class="btn btn-success w-100"
                    {{ not canBake or not cake.size or not cake.frostingFlavor or not cake.layers ? 'disabled' : '' }}
                >
                    🔥 Bake & Submit
                </button>
            </form>

            {% if not canBake %}
                <p class="text-danger small mt-2 mb-0">Not enough ingredients.</p>
            {% endif %}
        </div>
    </div>
</turbo-frame>
