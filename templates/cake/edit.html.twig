{% extends 'base.html.twig' %}

{% block title %}Baking for {{ order.customerName }}{% endblock %}

{% block navbar %}
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="{{ path('game_index') }}">🎂 Back to Orders</a>
            <div id="navbar-stats" class="d-flex gap-4 text-white small align-items-center">
                <span>💰 ${{ bakery.money|number_format(2) }}</span>
                <span>⭐ {{ bakery.reputation }}/100</span>
                <span>📅 Day {{ bakery.day }} / {{ bakery.maxDays }}</span>
            </div>
        </div>
    </nav>
{% endblock %}

{% block body %}
    <div class="row g-4">

        {# Order requirements #}
        <div class="col-md-3"
             {% if order.failsAt %}
             data-controller="order-timer"
             data-order-timer-spawn-at-value="{{ order.spawnAt.timestamp }}"
             data-order-timer-fails-at-value="{{ order.failsAt.timestamp }}"
             data-order-timer-server-now-value="{{ serverNow }}"
             {% endif %}>
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-1">
                        <h5 class="card-title mb-0">{{ order.customerName }}'s Order</h5>
                        {% if order.failsAt %}
                            <div style="min-width:100px">
                                <div class="text-end small mb-1" data-order-timer-target="patienceLabel">😊 Excited</div>
                                <div class="progress" style="height:5px">
                                    <div class="progress-bar bg-success" data-order-timer-target="patienceBar" style="width:100%"></div>
                                </div>
                            </div>
                        {% endif %}
                    </div>
                    {% if order.failsAt %}
                        <form method="post" action="{{ path('order_expire', {id: order.id}) }}"
                              data-order-timer-target="expireForm" class="d-none"></form>
                    {% endif %}
                    <ul class="list-unstyled small mt-2">
                        <li>🎂 {{ order.requiredSize.value }}</li>
                        <li>🍦 {{ order.requiredFrostingFlavor.label }}</li>
                        <li>📏 {{ order.requiredLayers }} layer{{ order.requiredLayers > 1 ? 's' : '' }}</li>
                        {% if order.requiredToppings %}
                            <li>✨ {{ order.requiredToppings|map(t => t.label)|join(', ') }}</li>
                        {% else %}
                            <li class="text-muted">No toppings required</li>
                        {% endif %}
                    </ul>
                    <hr>
                    <div class="text-success fw-semibold">Payout: ${{ order.payout|number_format(2) }}</div>
                </div>
            </div>
        </div>

        {# Cake builder #}
        <div class="col-md-6">
            {{ include('cake/_builder.html.twig') }}
        </div>

        {# Inventory sidebar #}
        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">Pantry</h5>
                    <ul class="list-unstyled small">
                        {% for key, qty in bakery.inventory %}
                            <li class="d-flex justify-content-between">
                                <span>{{ key|replace({'frosting_': '', 'topping_': '', '_': ' '})|title }}</span>
                                <span class="{{ qty < 3 ? 'text-danger' : 'text-muted' }}">{{ qty }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </div>

    </div>

{% endblock %}
