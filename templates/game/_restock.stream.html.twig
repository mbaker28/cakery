<turbo-stream action="replace" target="shop">
    <template>
        {{ include('game/_shop.html.twig') }}
    </template>
</turbo-stream>
<turbo-stream action="replace" target="navbar-stats">
    <template>
        <div id="navbar-stats" class="d-flex gap-4 text-white small align-items-center">
            <span>💰 ${{ bakery.money|number_format(2) }}</span>
            <span>⭐ {{ bakery.reputation }}/100</span>
            <span>📅 Day {{ bakery.day }}</span>
        </div>
    </template>
</turbo-stream>
{% if builderContext %}
<turbo-stream action="replace" target="ingredient-status">
    <template>
        {{ include('cake/_ingredient_status.html.twig', builderContext) }}
    </template>
</turbo-stream>
{% endif %}
{% if toastIngredient %}
<turbo-stream action="append" target="toast-container">
    <template>
        <div class="toast align-items-center text-bg-success border-0" role="alert" data-bs-autohide="true" data-bs-delay="4000">
            <div class="d-flex">
                <div class="toast-body fw-semibold">
                    Restocked {{ toastQuantity }}× {{ toastIngredient.label }} for ${{ (toastIngredient.costPerUnit * toastQuantity)|number_format(2) }}.
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </template>
</turbo-stream>
{% endif %}
