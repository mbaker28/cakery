{% extends 'base.html.twig' %}

{% block title %}Game Over{% endblock %}

{% block body %}
<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div class="display-1 mb-3">😰</div>
        <h1 class="display-4 fw-bold text-danger mb-2">Game Over</h1>
        <p class="lead text-muted mb-4">
            You ran out of money and couldn't afford the ingredients to complete your orders.
        </p>

        {% if bakery %}
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="card-title mb-3">{{ bakery.name }} — Final Stats</h5>
                    <div class="row g-3 text-center">
                        <div class="col-4">
                            <div class="h3 mb-0">{{ bakery.day }}</div>
                            <div class="text-muted small">Days survived</div>
                        </div>
                        <div class="col-4">
                            <div class="h3 mb-0">{{ bakery.ordersCompleted }}</div>
                            <div class="text-muted small">Orders completed</div>
                        </div>
                        <div class="col-4">
                            <div class="h3 mb-0 {{ bakery.money < 10 ? 'text-danger' : '' }}">${{ bakery.money|number_format(2) }}</div>
                            <div class="text-muted small">Money left</div>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}

        <form method="post" action="{{ path('game_restart') }}">
            <button class="btn btn-primary btn-lg px-5">Try Again</button>
        </form>
    </div>
</div>
{% endblock %}
