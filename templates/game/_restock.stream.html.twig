{% if success and item is not null %}
<turbo-stream action="replace" target="ingredient-{{ item.value }}">
    <template>
        {{ include('game/_shop_card.html.twig', {quantity: quantity}) }}
    </template>
</turbo-stream>
<turbo-stream action="update" target="navbar-money">
    <template>💰 ${{ bakery.money|number_format(2) }}</template>
</turbo-stream>
{% endif %}

{% if message is not null %}
<turbo-stream action="append" target="toast-container">
    <template>
        <div class="toast align-items-center text-bg-{{ success ? 'success' : 'danger' }} border-0"
             role="alert" data-bs-autohide="true" data-bs-delay="3000">
            <div class="d-flex">
                <div class="toast-body fw-semibold">{{ message }}</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </template>
</turbo-stream>
{% endif %}
