<turbo-frame id="cake-builder">
    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="card-title mb-4">Build your cake</h5>

            {# Size #}
            <div class="mb-4">
                <label class="form-label fw-semibold">Size</label>
                <div class="d-flex gap-2 flex-wrap">
                    {% for size in sizes %}
                        <form method="post" action="{{ path('cake_set_size', {id: order.id, cakeId: cake.id}) }}">
                            <input type="hidden" name="size" value="{{ size.value }}">
                            <button class="btn btn-sm {{ cake.size == size ? 'btn-primary' : 'btn-outline-secondary' }}">
                                {{ size.value }}
                            </button>
                        </form>
                    {% endfor %}
                </div>
            </div>

            {# Layers #}
            <div class="mb-4">
                <label class="form-label fw-semibold">Layers</label>
                <div class="d-flex gap-2">
                    {% for i in 1..5 %}
                        <form method="post" action="{{ path('cake_set_layers', {id: order.id, cakeId: cake.id}) }}">
                            <input type="hidden" name="layers" value="{{ i }}">
                            <button class="btn btn-sm {{ cake.layers == i ? 'btn-primary' : 'btn-outline-secondary' }}">
                                {{ i }}
                            </button>
                        </form>
                    {% endfor %}
                </div>
            </div>

            {# Frosting #}
            <div class="mb-4">
                <label class="form-label fw-semibold">Frosting</label>
                <div class="d-flex gap-2 flex-wrap">
                    {% for flavor in flavors %}
                        <form method="post" action="{{ path('cake_set_frosting', {id: order.id, cakeId: cake.id}) }}">
                            <input type="hidden" name="flavor" value="{{ flavor.value }}">
                            <button class="btn btn-sm {{ cake.frostingFlavor == flavor ? 'btn-primary' : 'btn-outline-secondary' }}">
                                {{ flavor.value }}
                            </button>
                        </form>
                    {% endfor %}
                </div>
            </div>

            {# Toppings #}
            <div class="mb-4">
                <label class="form-label fw-semibold">Toppings</label>
                <div class="d-flex gap-2 flex-wrap">
                    {% for topping in toppings %}
                        <form method="post" action="{{ path('cake_toggle_topping', {id: order.id, cakeId: cake.id}) }}">
                            <input type="hidden" name="topping" value="{{ topping.value }}">
                            <button class="btn btn-sm {{ cake.toppings and topping in cake.toppings ? 'btn-primary' : 'btn-outline-secondary' }}">
                                {{ topping.value }}
                            </button>
                        </form>
                    {% endfor %}
                </div>
            </div>

            {{ include('cake/_ingredient_status.html.twig') }}
        </div>
    </div>
</turbo-frame>
