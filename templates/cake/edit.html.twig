{% extends 'base.html.twig' %}

{% block title %}Baking for {{ order.customerName }}{% endblock %}

{% block navbar %}
    <nav class="navbar navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="{{ path('game_index') }}">🎂 Back to Orders</a>
            <div class="d-flex gap-4 text-white small align-items-center">
                <span>💰 ${{ bakery.money|number_format(2) }}</span>
                <span>⭐ {{ bakery.reputation }}/100</span>
                <span>📅 Day {{ bakery.day }}</span>
            </div>
        </div>
    </nav>
{% endblock %}

{% block body %}
    <div class="row g-4">

        {# Order requirements #}
        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">{{ order.customerName }}'s Order</h5>
                    <p class="text-muted small">Due day {{ order.dueDay }}</p>
                    <ul class="list-unstyled small">
                        <li>🎂 {{ order.requiredSize.value }}</li>
                        <li>🍦 {{ order.requiredFrostingFlavor.value }}</li>
                        <li>📏 {{ order.requiredLayers }} layer{{ order.requiredLayers > 1 ? 's' : '' }}</li>
                        {% if order.requiredToppings %}
                            <li>✨ {{ order.requiredToppings|map(t => t.value)|join(', ') }}</li>
                        {% else %}
                            <li class="text-muted">No toppings required</li>
                        {% endif %}
                    </ul>
                    <hr>
                    <div class="text-success fw-semibold">Payout: ${{ order.payout|number_format(2) }}</div>
                </div>
            </div>
        </div>

        {# Cake builder #}
        <div class="col-md-6">
            {{ include('cake/_builder.html.twig') }}
        </div>

        {# Inventory sidebar #}
        <div class="col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">Pantry</h5>
                    <ul class="list-unstyled small">
                        {% for key, qty in bakery.inventory %}
                            <li class="d-flex justify-content-between">
                                <span>{{ key|capitalize }}</span>
                                <span class="{{ qty < 3 ? 'text-danger' : 'text-muted' }}">{{ qty }}</span>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </div>

    </div>
{% endblock %}
