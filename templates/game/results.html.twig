{% extends 'base.html.twig' %}

{% block title %}Results — {{ bakery.name }}{% endblock %}

{% block body %}
    {% set title = bakery.reputation >= 75 ? 'Master Baker'
        : bakery.reputation >= 50 ? 'Expert Baker'
        : bakery.reputation >= 25 ? 'Apprentice Baker'
        : 'Struggling Baker' %}

    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm text-center">
                <div class="card-body p-5">
                    <div class="display-4 mb-2">🎂</div>
                    <h1 class="h2 mb-1">{{ bakery.name }}</h1>
                    <p class="text-muted mb-4">{{ bakery.maxDays }}-day challenge complete</p>

                    <div class="display-6 fw-bold mb-1">{{ title }}</div>
                    <p class="text-muted mb-4">⭐ {{ bakery.reputation }}/100 reputation</p>

                    <div class="row g-3 mb-4 text-start">
                        <div class="col-6">
                            <div class="card bg-light border-0">
                                <div class="card-body py-3">
                                    <div class="small text-muted">Final balance</div>
                                    <div class="h4 mb-0 text-success">${{ bakery.money|number_format(2) }}</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="card bg-light border-0">
                                <div class="card-body py-3">
                                    <div class="small text-muted">Reputation</div>
                                    <div class="h4 mb-0">{{ bakery.reputation }}/100</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="card bg-light border-0">
                                <div class="card-body py-3">
                                    <div class="small text-muted">Orders completed</div>
                                    <div class="h4 mb-0 text-success">{{ bakery.ordersCompleted }}</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="card bg-light border-0">
                                <div class="card-body py-3">
                                    <div class="small text-muted">Orders failed</div>
                                    <div class="h4 mb-0 text-danger">{{ bakery.ordersFailed }}</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <form method="post" action="{{ path('game_restart') }}">
                        <button class="btn btn-primary btn-lg w-100">Play Again</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
