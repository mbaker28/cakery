<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Cakery{% endblock %}</title>
        {% block stylesheets %}{% endblock %}
        {% block javascripts %}
            {{ importmap('app') }}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
            <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
            <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
            <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        {% block navbar %}{% endblock %}
        <main class="container py-4">
            {% block body %}{% endblock %}
        </main>

        <div id="notification-toast-container" class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1090;" data-turbo-permanent></div>

        <div id="toast-container" class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1080;">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="toast align-items-center text-bg-{{ type == 'success' ? 'success' : 'danger' }} border-0"
                         role="alert" data-bs-autohide="true" data-bs-delay="5000">
                        <div class="d-flex">
                            <div class="toast-body fw-semibold">{{ message }}</div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                        </div>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>
    </body>
</html>
